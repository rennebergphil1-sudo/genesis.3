# Discord Bot Token (Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Groq API Key für die KI-Generierung der Baupläne (https://console.groq.com)
GROQ_API_KEY=

# Deine Discord-User-ID (nicht Server-ID!) für die Owner-only /genesis-admin
# Befehle (Wartungsmodus, Server sperren, Audit-Log, Server verlassen).
# Entwicklermodus an -> Rechtsklick auf deinen eigenen Namen -> "ID kopieren"
OWNER_ID=

# Optional: Pfad zur Backup-Speicherdatei
BACKUPS_FILE=backups.json
